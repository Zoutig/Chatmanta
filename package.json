{
  "name": "chatmanta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "check-env": "node --env-file=.env.local scripts/check-env.mjs",
    "verify-schema": "node --env-file=.env.local scripts/verify-schema.mjs",
    "v0:ingest": "node --env-file=.env.local scripts/v0-ingest.mjs",
    "v0:chat": "node --env-file=.env.local scripts/v0-chat.mjs",
    "v0:list": "node --env-file=.env.local scripts/v0-list-docs.mjs",
    "v0:reset": "node --env-file=.env.local scripts/v0-reset.mjs",
    "v0:tune": "node --env-file=.env.local scripts/v0-tune-threshold.mjs",
    "v0:snapshot": "node --env-file=.env.local scripts/v0-snapshot.mjs",
    "v0:reingest-parents": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-reingest-parents.ts",
    "v0:seed-orgs": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-seed-orgs.ts",
    "v0:test-org-isolation": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-test-org-isolation.ts",
    "eval:seed": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-eval-seed.ts",
    "eval:run": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-eval-run.ts",
    "eval:report": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-eval-report.ts",
    "eval:run-all": "npm run eval:seed && npm run eval:run && npm run eval:report",
    "eval:relabel": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-eval-relabel.ts",
    "audit:retrieval": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-retrieval-audit.ts",
    "audit:labels": "node --env-file=.env.local --conditions=react-server --import tsx scripts/v0-eval-label-doctor.ts",
    "cc:backfill-prs": "node scripts/cc/backfill-prs.mjs",
    "cc:clean-slate": "node scripts/cc/clean-slate.mjs",
    "cc:seed-v0-milestones": "node scripts/cc/seed-v0-milestones.mjs",
    "migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "migrate:status": "node --env-file=.env.local scripts/migrate.mjs status",
    "migrate:bootstrap": "node --env-file=.env.local scripts/migrate.mjs bootstrap",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@ark-ui/react": "^5.36.2",
    "@mendable/firecrawl-js": "^4.25.0",
    "@paper-design/shaders-react": "^0.0.76",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
