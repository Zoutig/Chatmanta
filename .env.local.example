# ChatManta — environment variables template
#
# Kopieer dit bestand naar `.env.local` (zonder .example) en vul de echte waarden in.
# `.env.local` staat in .gitignore en wordt NOOIT gecommit.
# Zelfde variabelen ook in Vercel dashboard zetten (Settings -> Environment Variables).
#
# Verplichte basis (Fase 1):

# Supabase — twee gescheiden projecten (kickoff §3, V0/V1-namespace-split):
#   V0 = sandbox/RAG-leerplatform (fake demo-data, server-only, GEEN NEXT_PUBLIC_).
#   V1 = productie (auth + multi-tenancy); de anon/url zijn browser-bereikbaar
#        (NEXT_PUBLIC_), de service-role-key blijft server-only.
# De oude unprefixed namen (NEXT_PUBLIC_SUPABASE_*, SUPABASE_SERVICE_ROLE_KEY)
# zijn vervangen door dit schema en worden bij de cutover volledig verwijderd.
V0_SUPABASE_URL=https://<v0-project-ref>.supabase.co
V0_SUPABASE_SERVICE_ROLE_KEY=<v0-service-role-key>
NEXT_PUBLIC_V1_SUPABASE_URL=https://<v1-project-ref>.supabase.co
NEXT_PUBLIC_V1_SUPABASE_ANON_KEY=<v1-anon-key>
V1_SUPABASE_SERVICE_ROLE_KEY=<v1-service-role-key>

# Voor de migration-runners — directe Postgres-connections (pooler, URI mode).
# Te vinden in Supabase dashboard → Project Settings → Database →
# Connection string → URI mode. Vervang het wachtwoord.
#   DATABASE_URL    → V0-project (`npm run migrate`)
#   V1_DATABASE_URL → V1-project (`npm run migrate:v1`)
DATABASE_URL=postgresql://postgres.<v0-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
V1_DATABASE_URL=postgresql://postgres.<v1-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

NEXT_PUBLIC_PRODUCT_NAME=ChatManta
NEXT_PUBLIC_APP_URL=https://chatmanta.vercel.app

# Verplicht voor V0 RAG-flow (en Fase 4):
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key

# Verplicht voor V0 web-demo (auth-gate op publieke Vercel URL):
V0_DEMO_PASSWORD=kies-een-wachtwoord
V0_COOKIE_SECRET=  # genereer met: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"

# Voor latere fases — placeholders, vul pas in wanneer de fase begint:

# Fase 2 — Sentry (error tracking)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Fase 5 — Crawler
# FIRECRAWL_API_KEY=

# Fase 6 — Widget security
# WIDGET_SIGNING_SECRET=  # genereer met: openssl rand -hex 32

# Rate limiting — optioneel.
#
# Default (geen van deze vars gezet): in-memory limiter, 30 req/min/IP op
# /api/v0/chat, 10 req/min/IP op mutatie-server-actions (ingestAction,
# removeDocAction, deleteThreadAction). Goed-genoeg voor V0 single-instance dev.
#
# Voor productie (V1): zet USE_UPSTASH=true en vul de Redis-vars hieronder in.
# Counter staat dan in een centrale Redis, dus alle Vercel-instances delen
# één bucket (effectief limiet = ingestelde limiet, niet N × limiet).
#
# Gratis Upstash-account: https://upstash.com/ → maak een Redis-database aan
# (regio EU = Frankfurt/Ireland) → kopieer "REST API" URL + Token.
#
# USE_UPSTASH=false  # 'true' zet Upstash aan; default = in-memory
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Optionele overrides voor de limieten (alleen invullen als je iets anders wilt):
# RATE_LIMIT_PER_MIN=30           # chat-limiter (default 30)
# MUTATION_RATE_LIMIT_PER_MIN=10  # mutatie-limiter (default 10)

# Fase 7 — Cron auth
# CRON_SECRET=  # genereer met: openssl rand -hex 32

# Feedbacksysteem Fase 3 — e-mailnotificaties (Resend). Fail-safe: zonder key worden
# mails overgeslagen (de melding wordt altijd opgeslagen). Activeer door deze te zetten:
# RESEND_API_KEY=                                  # Resend API-key (server-only, nooit NEXT_PUBLIC_*)
# RESEND_FROM=ChatManta <feedback@chatmanta.nl>    # afzender op een geverifieerd Resend-domein
# FEEDBACK_NOTIFY_EMAIL=niels@chatmanta.com        # ontvanger van de operator-notificatie
# NEXT_PUBLIC_APP_URL=https://www.chatmanta.nl     # basis-URL voor de deeplink in de mail
