# ChatManta — environment variables template
#
# Kopieer dit bestand naar `.env.local` (zonder .example) en vul de echte waarden in.
# `.env.local` staat in .gitignore en wordt NOOIT gecommit.
# Zelfde variabelen ook in Vercel dashboard zetten (Settings -> Environment Variables).
#
# Verplichte basis (Fase 1):

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-jwt
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-jwt

# Voor `npm run migrate` — directe Postgres-connection.
# Te vinden in Supabase dashboard → Project Settings → Database →
# Connection string → URI mode. Vervang [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

NEXT_PUBLIC_PRODUCT_NAME=ChatManta
NEXT_PUBLIC_APP_URL=https://chatmanta.vercel.app

# Verplicht voor V0 RAG-flow (en Fase 4):
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key

# Verplicht voor V0 web-demo (auth-gate op publieke Vercel URL):
V0_DEMO_PASSWORD=kies-een-wachtwoord
V0_COOKIE_SECRET=  # genereer met: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"

# Voor latere fases — placeholders, vul pas in wanneer de fase begint:

# Fase 2 — Sentry (error tracking)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Fase 5 — Crawler
# FIRECRAWL_API_KEY=

# Fase 6 — Widget security
# WIDGET_SIGNING_SECRET=  # genereer met: openssl rand -hex 32

# Rate limiting — optioneel.
#
# Default (geen van deze vars gezet): in-memory limiter, 30 req/min/IP op
# /api/v0/chat, 10 req/min/IP op mutatie-server-actions (ingestAction,
# removeDocAction, deleteThreadAction). Goed-genoeg voor V0 single-instance dev.
#
# Voor productie (V1): zet USE_UPSTASH=true en vul de Redis-vars hieronder in.
# Counter staat dan in een centrale Redis, dus alle Vercel-instances delen
# één bucket (effectief limiet = ingestelde limiet, niet N × limiet).
#
# Gratis Upstash-account: https://upstash.com/ → maak een Redis-database aan
# (regio EU = Frankfurt/Ireland) → kopieer "REST API" URL + Token.
#
# USE_UPSTASH=false  # 'true' zet Upstash aan; default = in-memory
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Optionele overrides voor de limieten (alleen invullen als je iets anders wilt):
# RATE_LIMIT_PER_MIN=30           # chat-limiter (default 30)
# MUTATION_RATE_LIMIT_PER_MIN=10  # mutatie-limiter (default 10)

# Fase 7 — Cron auth
# CRON_SECRET=  # genereer met: openssl rand -hex 32

# Fase 7 — Email (Resend)
# RESEND_API_KEY=
